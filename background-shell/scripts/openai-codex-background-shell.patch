+
+    async fn update_background_wakeup(
+        &self,
+        notification_id: &str,
+        phase: BackgroundWakeupPhase,
+        dispatch_path: Option<String>,
+        dispatch_error: Option<String>,
+        observed_turn_id: Option<String>,
+    ) {
+        let mut wakeups = self.background_terminal_wakeups.lock().await;
+        let Some(wakeup) = wakeups
+            .iter_mut()
+            .find(|wakeup| wakeup.notification_id == notification_id)
+        else {
+            return;
+        };
+        if matches!(
+            wakeup.phase,
+            BackgroundWakeupPhase::Delivered | BackgroundWakeupPhase::DispatchFailed
+        ) && phase != wakeup.phase
+        {
+            return;
+        }
+        wakeup.phase = phase;
+        if let Some(dispatch_path) = dispatch_path {
+            wakeup.dispatch_path = Some(dispatch_path);
+        }
+        if let Some(dispatch_error) = dispatch_error {
+            wakeup.dispatch_error = Some(dispatch_error);
+        }
+        if let Some(observed_turn_id) = observed_turn_id {
+            wakeup.observed_turn_id = Some(observed_turn_id);
+        }
+    }
+
+    fn spawn_background_wakeup_watchdog(self: &Arc<Self>, notification_id: String) {
+        let session = Arc::clone(self);
+        tokio::spawn(async move {
+            tokio::time::sleep(background_wakeup_stuck_timeout()).await;
+            session
+                .update_background_wakeup_if_still_pending_delivery(&notification_id)
+                .await;
+        });
+    }
+
+    fn spawn_deferred_background_wakeup_idle_turn(
+        self: &Arc<Self>,
+        notification_id: String,
+        items: Vec<ResponseItem>,
+        dispatch_path: String,
+    ) {
+        let session = Arc::clone(self);
+        let runtime = tokio::runtime::Handle::current();
+        let thread_name = format!("codex-bg-wakeup-{}", notification_id);
+        let notification_id_for_thread = notification_id.clone();
+        let spawn_result = std::thread::Builder::new()
+            .name(thread_name)
+            .stack_size(8 * 1024 * 1024)
+            .spawn(move || {
+                runtime.block_on(async move {
+                    let deadline =
+                        tokio::time::Instant::now() + background_wakeup_deferred_idle_timeout();
+                    let mut pending_items = Some(items);
+                    loop {
+                        if tokio::time::Instant::now() >= deadline {
+                            session
+                                .update_background_wakeup(
+                                    &notification_id_for_thread,
+                                    BackgroundWakeupPhase::DispatchFailed,
+                                    None,
+                                    Some(BACKGROUND_WAKEUP_STUCK_MESSAGE.to_string()),
+                                    None,
+                                )
+                                .await;
+                            return;
+                        }
+
+                        if session.active_turn.lock().await.is_none() {
+                            let items = pending_items.take().unwrap_or_default();
+                            match session.try_start_turn_if_idle(items).await {
+                                Ok(()) => {
+                                    session
+                                        .update_background_wakeup(
+                                            &notification_id_for_thread,
+                                            BackgroundWakeupPhase::ModelObserved,
+                                            Some(dispatch_path),
+                                            None,
+                                            None,
+                                        )
+                                        .await;
+                                    session.spawn_background_wakeup_watchdog(
+                                        notification_id_for_thread,
+                                    );
+                                    return;
+                                }
+                                Err(err)
+                                    if matches!(
+                                        err.reason(),
+                                        TryStartTurnIfIdleRejectionReason::Busy
+                                            | TryStartTurnIfIdleRejectionReason::PendingTriggerTurn
+                                    ) =>
+                                {
+                                    pending_items = Some(err.into_input());
+                                }
+                                Err(err) => {
+                                    session
+                                        .update_background_wakeup(
+                                            &notification_id_for_thread,
+                                            BackgroundWakeupPhase::DispatchFailed,
+                                            None,
+                                            Some(format!(
+                                                "deferred idle dispatch rejected: {:?}",
+                                                err.reason()
+                                            )),
+                                            None,
+                                        )
+                                        .await;
+                                    return;
+                                }
+                            }
+                        }
+
+                        tokio::time::sleep(Duration::from_millis(250)).await;
+                    }
+                });
+            });
+
+        if let Err(error) = spawn_result {
+            let session = Arc::clone(self);
+            tokio::spawn(async move {
+                session
+                    .update_background_wakeup(
+                        &notification_id,
+                        BackgroundWakeupPhase::DispatchFailed,
+                        None,
+                        Some(format!("deferred idle thread spawn failed: {error}")),
+                        None,
+                    )
+                    .await;
+            });
+        }
+    }
+
+    async fn update_background_wakeup_if_still_pending_delivery(&self, notification_id: &str) {
+        let mut wakeups = self.background_terminal_wakeups.lock().await;
+        let Some(wakeup) = wakeups
+            .iter_mut()
+            .find(|wakeup| wakeup.notification_id == notification_id)
+        else {
+            return;
+        };
+        if matches!(
+            wakeup.phase,
+            BackgroundWakeupPhase::RpcAccepted | BackgroundWakeupPhase::ModelObserved
+        ) {
+            wakeup.phase = BackgroundWakeupPhase::DispatchFailed;
+            wakeup.dispatch_error = Some(BACKGROUND_WAKEUP_STUCK_MESSAGE.to_string());
+        }
+    }
+}
+
+fn background_wakeup_stuck_timeout() -> Duration {
+    if cfg!(test) {
+        Duration::from_millis(200)
+    } else {
+        Duration::from_secs(120)
+    }
+}
+
+fn background_wakeup_deferred_idle_timeout() -> Duration {
+    if cfg!(test) {
+        Duration::from_secs(2)
+    } else {
+        Duration::from_secs(900)
+    }
+}
+
+fn summarize_background_output(output: &str) -> String {
+    let trimmed = output.trim();
+    if trimmed.is_empty() {
+        return "<no output>".to_string();
+    }
+    let mut summary = trimmed.chars().take(1200).collect::<String>();
+    if trimmed.chars().count() > summary.chars().count() {
+        summary.push_str("\n[truncated]");
+    }
+    summary
+}
+
