+async fn background_terminal_exit_wakeup_is_model_observed_then_delivered() -> anyhow::Result<()> {
+    skip_if_sandbox!(Ok(()));
+
+    let (session, turn) = test_session_and_turn().await;
+    let manager = &session.services.unified_exec_manager;
+    let process_id = manager.allocate_process_id().await;
+    let context = UnifiedExecContext::new(
+        Arc::clone(&session),
+        Arc::clone(&turn),
+        "call-background-wakeup".to_string(),
+    );
+    let command = "sleep 0.25; echo background-wakeup-done";
+    let request = exec_command_request_for_test(
+        &turn,
+        command,
+        process_id,
+        /*yield_time_ms*/ 30_000,
+        /*run_in_background*/ true,
+        BackgroundTransitionSource::Explicit,
+    );
+
+    let output = manager.exec_command(request, &context).await?;
+    assert_eq!(output.process_id, Some(process_id));
+    {
+        let mut active_turn = session.active_turn.lock().await;
+        *active_turn = Some(ActiveTurn::default());
+    }
+
+    tokio::time::timeout(Duration::from_secs(2), async {
+        loop {
+            let wakeups = session.list_background_terminal_wakeups().await;
+            if wakeups
+                .first()
+                .is_some_and(|wakeup| wakeup.phase == BackgroundWakeupPhase::RpcAccepted)
+            {
+                break;
+            }
+            tokio::time::sleep(Duration::from_millis(20)).await;
+        }
+    })
+    .await
+    .expect("background completion wakeup should be accepted while the active turn is busy");
+    tokio::time::timeout(Duration::from_secs(1), async {
+        while !session.list_background_terminals().await.is_empty() {
+            tokio::task::yield_now().await;
+        }
+    })
+    .await
+    .expect("completed background terminal should be removed from the active list");
+
+    let wakeup = session
+        .list_background_terminal_wakeups()
+        .await
+        .into_iter()
+        .next()
+        .expect("wakeup record");
+    assert_eq!(wakeup.item_id, "call-background-wakeup");
+    assert_eq!(wakeup.process_id, process_id.to_string());
+    assert_eq!(wakeup.command, command);
+    assert_eq!(wakeup.exit_code, 0);
+    assert_eq!(
+        wakeup.dispatch_path.as_deref(),
+        Some("busy_deferred_idle_turn")
+    );
+    assert!(
+        wakeup.output_summary.contains("background-wakeup-done"),
+        "output summary should include terminal output: {:?}",
+        wakeup.output_summary
+    );
+
+    {
+        let mut active_turn = session.active_turn.lock().await;
+        *active_turn = None;
+    }
+
+    tokio::time::timeout(Duration::from_secs(2), async {
+        loop {
+            let wakeups = session.list_background_terminal_wakeups().await;
+            if wakeups
+                .first()
+                .is_some_and(|wakeup| wakeup.phase == BackgroundWakeupPhase::ModelObserved)
+            {
+                break;
+            }
+            tokio::time::sleep(Duration::from_millis(20)).await;
+        }
+    })
+    .await
+    .expect(
+        "deferred background wakeup should start an idle model turn after the active turn ends",
+    );
+    assert!(
+        session.active_turn.lock().await.is_some(),
+        "deferred busy wakeup should reserve and start a follow-up turn"
+    );
+
+    session
+        .send_event(
+            turn.as_ref(),
+            EventMsg::AgentMessage(AgentMessageEvent {
+                message: format!("Handled {}", wakeup.notification_id),
+                phase: None,
+                memory_citation: None,
+            }),
+        )
+        .await;
+
+    let delivered = session
+        .list_background_terminal_wakeups()
+        .await
+        .into_iter()
+        .next()
+        .expect("delivered wakeup record");
+    assert_eq!(delivered.phase, BackgroundWakeupPhase::Delivered);
+    assert_eq!(
+        delivered.observed_turn_id.as_deref(),
+        Some(turn.sub_id.as_str())
+    );
+
+    Ok(())
+}
