+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn shell_command_run_in_background_registers_native_terminal() -> anyhow::Result<()> {
+    skip_if_sandbox!(Ok(()));
+
+    let (session, mut turn) = make_session_and_context().await;
+    turn.permission_profile = PermissionProfile::Disabled;
+    let session = Arc::new(session);
+    let turn = Arc::new(turn);
+    let handler = ShellCommandHandler::from(codex_tools::ShellCommandBackendConfig::Classic);
+    let command = "printf shell-background-start; sleep 2";
+    let call_id = "call-shell-background".to_string();
+    #[allow(deprecated)]
+    let workdir = turn.cwd.to_string_lossy().to_string();
+
+    let _output = handler
+        .handle(ToolInvocation {
+            session: Arc::clone(&session),
+            step_context: StepContext::for_test(Arc::clone(&turn)),
+            turn: Arc::clone(&turn),
+            cancellation_token: tokio_util::sync::CancellationToken::new(),
+            tracker: Arc::new(Mutex::new(TurnDiffTracker::new())),
+            call_id: call_id.clone(),
+            tool_name: codex_tools::ToolName::plain("shell_command"),
+            source: ToolCallSource::Direct,
+            payload: ToolPayload::Function {
+                arguments: json!({
+                    "command": command,
+                    "workdir": workdir,
+                    "run_in_background": true,
+                })
+                .to_string(),
+            },
+        })
+        .await
+        .map_err(|err| anyhow::anyhow!(err.to_string()))?;
+
+    let terminals = session.list_background_terminals().await;
+    assert_eq!(terminals.len(), 1);
+    assert_eq!(terminals[0].item_id, call_id);
+    assert_eq!(terminals[0].command, command);
+    assert_eq!(terminals[0].source, "explicit_tool");
+
+    let process_id = terminals[0].process_id.parse::<i32>()?;
+    assert!(
+        session
+            .services
+            .unified_exec_manager
+            .terminate_process(process_id)
+            .await
+    );
+    Ok(())
+}
