+                                                "deferred idle dispatch rejected: {:?}",
+                                                err.reason()
+                                            )),
+                                            None,
+                                        )
+                                        .await;
+                                    return;
+                                }
+                            }
+                        }
+
+                        tokio::time::sleep(Duration::from_millis(250)).await;
+                    }
+                });
+            });
+
+        if let Err(error) = spawn_result {
+            let session = Arc::clone(self);
+            tokio::spawn(async move {
+                session
+                    .update_background_wakeup(
+                        &notification_id,
+                        BackgroundWakeupPhase::DispatchFailed,
+                        None,
+                        Some(format!("deferred idle thread spawn failed: {error}")),
+                        None,
+                    )
+                    .await;
+            });
+        }
+    }
+
+    async fn update_background_wakeup_if_still_pending_delivery(&self, notification_id: &str) {
+        let mut wakeups = self.background_terminal_wakeups.lock().await;
+        let Some(wakeup) = wakeups
+            .iter_mut()
+            .find(|wakeup| wakeup.notification_id == notification_id)
+        else {
+            return;
+        };
+        if matches!(
+            wakeup.phase,
+            BackgroundWakeupPhase::RpcAccepted | BackgroundWakeupPhase::ModelObserved
+        ) {
+            wakeup.phase = BackgroundWakeupPhase::DispatchFailed;
+            wakeup.dispatch_error = Some(BACKGROUND_WAKEUP_STUCK_MESSAGE.to_string());
+        }
+    }
+}
+
+fn background_wakeup_stuck_timeout() -> Duration {
+    if cfg!(test) {
+        Duration::from_millis(200)
+    } else {
+        Duration::from_secs(120)
+    }
+}
+
+fn background_wakeup_deferred_idle_timeout() -> Duration {
+    if cfg!(test) {
+        Duration::from_secs(2)
+    } else {
+        Duration::from_secs(900)
+    }
+}
+
+fn summarize_background_output(output: &str) -> String {
+    let trimmed = output.trim();
+    if trimmed.is_empty() {
+        return "<no output>".to_string();
+    }
+    let mut summary = trimmed.chars().take(1200).collect::<String>();
+    if trimmed.chars().count() > summary.chars().count() {
+        summary.push_str("\n[truncated]");
+    }
+    summary
+}
+
+fn format_background_wakeup_prompt(wakeup: &BackgroundWakeupInfo) -> String {
+    format!(
+        "Background terminal completed.\n\
+         Notification phase: {}\n\
+         Task id: {}\n\
+         Process id: {}\n\
+         Command: {}\n\
+         CWD: {}\n\
+         Exit status: {}\n\
+         Output path: {}\n\
+         Output entry: {}\n\
+         Output summary:\n{}\n\
+         Suggested next step: {}\n\
+         Please mention task id {} in your response so Codex can confirm model consumption.",
+        wakeup.phase_name(),
+        wakeup.notification_id,
+        wakeup.process_id,
+        wakeup.command,
+        wakeup.cwd,
+        wakeup.exit_code,
+        wakeup
+            .output_path
+            .as_deref()
+            .unwrap_or("<not materialized>"),
+        wakeup.output_entry,
+        wakeup.output_summary,
+        wakeup.suggested_next_step,
+        wakeup.notification_id
+    )
+}
+
+fn background_wakeup_observation_text(msg: &EventMsg) -> Option<String> {
+    match msg {
+        EventMsg::AgentMessage(event) => Some(event.message.clone()),
+        EventMsg::ItemCompleted(event) => Some(format!("{:?}", event.item)),
+        _ => None,
+    }
+}
+
+fn background_wakeup_text_matches(wakeup: &BackgroundWakeupInfo, text: &str) -> bool {
+    text.contains(&wakeup.notification_id)
+        || (!wakeup.process_id.is_empty() && text.contains(&wakeup.process_id))
+        || (!wakeup.command.is_empty() && text.contains(&wakeup.command))
 }
